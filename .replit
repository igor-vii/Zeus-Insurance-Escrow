modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && PORT=5000 pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd api-server && PORT=8080 pnpm dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[userenv]

[userenv.shared]
TOKEN_ADDRESS = "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
VITE_ESCROW_BOT_ADDRESS = "0x87365462353bCBAB2CF0DF57c7Cb15519C5B7c76"
ZEUS_ESCROW_BOT_ADDRESS = "0x87365462353bCBAB2CF0DF57c7Cb15519C5B7c76"
ESCROW_DEPLOY_BLOCK = "44268060"
ZEUS_INSURANCE_ADDRESS = "0x1d9D90d2652296A2c89E3802d45B1F2132b30076"
TREASURY_ADDRESS = "0xaF8c45345e79dA97Dd41db5FE04d13ad4BEB1640"
ZEUS_ESCROW_BOT_MAINNET_ADDRESS = "0x8D10C2c6C92b613C1938fe532f0e391044e76188"
ZEUS_NETWORK = "base-mainnet"
ZEUS_INSURANCE_NETWORK = "base-sepolia"
