modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && PORT=5000 pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd api-server && PORT=8080 pnpm dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[userenv]

[userenv.shared]
TOKEN_ADDRESS = "0x036CbD53842c5426634e7929541eC2318f3dCF7e"
VITE_ESCROW_BOT_ADDRESS = "0x87365462353bCBAB2CF0DF57c7Cb15519C5B7c76"
ZEUS_ESCROW_BOT_ADDRESS = "0x87365462353bCBAB2CF0DF57c7Cb15519C5B7c76"
ESCROW_DEPLOY_BLOCK = "44268060"
