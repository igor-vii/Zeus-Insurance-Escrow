# Zeus Insurance — API Server environment variables
# For Replit: set values via Replit Secrets / Environment Variables UI.
# For local dev: copy to .env and fill in values (never commit real secrets).

# ── Network ───────────────────────────────────────────────────────────────────
ZEUS_NETWORK=base-sepolia
ZEUS_INSURANCE_NETWORK=base-sepolia

# ── Base Sepolia (testnet) ────────────────────────────────────────────────────
ZEUS_INSURANCE_ADDRESS=0x58038Df01A824C94F3D2fEd6d4e1bEf2211Ad8F4
ZEUS_ESCROW_BOT_ADDRESS=0x87365462353bCBAB2CF0DF57c7Cb15519C5B7c76
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── X Layer Mainnet (OKX L2, chainId 196) — deployed 2026-07-21 ──────────────
ZEUS_INSURANCE_ADDRESS_XLAYER=0x8D10C2c6C92b613C1938fe532f0e391044e76188
ZEUS_ESCROW_ADDRESS_XLAYER=0x0d4AD4C6b60F445d0e478E0AF48075340AC51Cf5
ZEUS_ESCROW_BOT_ADDRESS_XLAYER=0x0d4AD4C6b60F445d0e478E0AF48075340AC51Cf5
ZEUS_RESERVE_ADDRESS_XLAYER=0xadED902c2C6dD7D1B5b72A6a0A3358a9b9d4A79c
XLAYER_MAINNET_RPC_URL=https://rpc.xlayer.tech

# ── Treasury (receives x402 fees) ────────────────────────────────────────────
# ZEUS_TREASURY=0x...

# ── Secrets (set via Replit Secrets, never store values here) ─────────────────
# SESSION_SECRET=
# SERVER_PRIVATE_KEY=
# OKLINK_API_KEY=    ← needed for X Layer contract verification on OKLink
